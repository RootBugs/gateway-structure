# ============================================================================
# Kwen Gateway — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================================

# Database — Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase — Find these in: Supabase Dashboard → Settings → API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# JWT & Session Security (Required — min 32 chars)
JWT_SECRET="[GENERATE-A-SECURE-SECRET]"
ENCRYPTION_KEY="[GENERATE-A-32-CHAR-KEY]"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# Provider API Keys (set at least one)
# For multiple keys per provider, use the _KEYS (plural) format with comma-separated values:
#   OPENROUTER_API_KEYS="key1,key2,key3,key4,key5"
# The system will rotate through all keys on rate limits (429) automatically.
# You can use either _KEYS (plural) or _KEY (singular) format — both work.
GEMINI_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEYS=""
CEREBRAS_API_KEY=""
SAMBANOVA_API_KEY=""
COHERE_API_KEY=""
HUGGINGFACE_API_KEY=""
TOGETHER_API_KEY=""
FIREWORKS_API_KEY=""
XIAOMIMIMO_API_KEY=""

# OpenRouter supports multiple keys — comma-separated for automatic rotation.
# The system round-robins across all keys and immediately switches on 429.
# Example: OPENROUTER_API_KEYS="sk-or-v1-xxx,sk-or-v1-yyy,sk-or-v1-zzz"

# Local Providers (Optional)
OLLAMA_BASE_URL="http://localhost:11434"
VLLM_BASE_URL="http://localhost:8000"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE="60"
RATE_LIMIT_REQUESTS_PER_HOUR="1000"

# Key Rotation Tuning
# KEY_COOLDOWN_MS: how long to wait before retrying a failed key (in ms)
#   Default: 60000 (60 seconds). Increase for stricter rate-limit handling.
KEY_COOLDOWN_MS="60000"
# MAX_KEY_FAILURES: max consecutive failures before a key is blacklisted
#   Default: 3. Decrease if keys should fail fast.
MAX_KEY_FAILURES="3"
# MAX_KEY_FORCE_RESETS: max force-resets when all keys are in cooldown
#   Default: 2. Higher keeps trying longer.
MAX_KEY_FORCE_RESETS="2"

# Routing Weights
ROUTING_WEIGHT_HEALTH="0.35"
ROUTING_WEIGHT_QUOTA="0.25"
ROUTING_WEIGHT_LATENCY="0.20"
ROUTING_WEIGHT_PRIORITY="0.20"

# Logging
LOG_LEVEL="info"
ENABLE_REQUEST_LOGGING="true"

# Node Environment
NODE_ENV="development"
